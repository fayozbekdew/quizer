{
  "name": "mindping",
  "version": "2.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node scripts/electron-dev.cjs",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "dist:mac": "npm run build && electron-builder --mac",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mindping.app",
    "productName": "MindPing",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
